diff --git a/src/cmd/go/internal/work/git_blob.go b/src/cmd/go/internal/work/git_blob.go
new file mode 100644
index 0000000000..1b204a23cb
--- /dev/null
+++ b/src/cmd/go/internal/work/git_blob.go
@@ -0,0 +1,96 @@
+// Copyright 2024 The Go Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style
+// license that can be found in the LICENSE file.
+
+package work
+
+import (
+	"fmt"
+	"os"
+	"strings"
+
+	"cmd/go/internal/base"
+	"cmd/go/internal/modindex"
+	"cmd/go/internal/vcs"
+)
+
+// initGitBlobs detects whether the current working directory is inside
+// a git repository (using the same vcs.FromDir detection as buildvcs)
+// and, if so, parses the git index for later lookup. The parsed index
+// retains the raw file bytes and an offset table — no per-entry string
+// or map allocations are performed at init time.
+//
+// All git index optimizations are disabled when GONOBITINDEX=1.
+func (b *Builder) initGitBlobs() {
+	if os.Getenv("GONOBITINDEX") != "" {
+		return
+	}
+
+	repoRoot, vcsCmd, err := vcs.FromDir(base.Cwd(), "")
+	if err != nil {
+		return
+	}
+	if vcsCmd.Cmd != "git" {
+		return
+	}
+
+	gitDir := vcs.ResolveGitDir(repoRoot)
+	if gitDir == "" {
+		return
+	}
+
+	idx, err := vcs.ReadGitIndex(gitDir)
+	if err != nil {
+		return
+	}
+
+	if idx.Len() > 0 {
+		b.gitIndex = idx
+		b.gitRepoRoot = repoRoot + "/"
+
+		// Set the git file hash function for modindex dirHash optimization.
+		// This allows dirHash to use git blob SHAs instead of per-file lstat.
+		modindex.GitFileHash = func(absPath string) (string, bool) {
+			return b.gitBlobHash(absPath)
+		}
+	}
+
+	// Register stats printer if instrumentation is enabled.
+	if os.Getenv("GODEBUG_MODINDEX") != "" {
+		base.AtExit(func() {
+			hit, miss, dirErr := modindex.IdxPkgStats()
+			nonReg, readErr, tooNew, infoErr := modindex.DirHashStats()
+			gitHit, gitMiss := modindex.DirHashGitStats()
+			fileInfoCalls := modindex.GetFileInfoCount()
+			fmt.Fprintf(os.Stderr, "\n=== modindex stats ===\n")
+			fmt.Fprintf(os.Stderr, "  idxPkg cache hit:  %d\n", hit)
+			fmt.Fprintf(os.Stderr, "  idxPkg cache miss: %d\n", miss)
+			fmt.Fprintf(os.Stderr, "  idxPkg dirErr:     %d\n", dirErr)
+			fmt.Fprintf(os.Stderr, "  dirHash nonReg:    %d\n", nonReg)
+			fmt.Fprintf(os.Stderr, "  dirHash readErr:   %d\n", readErr)
+			fmt.Fprintf(os.Stderr, "  dirHash tooNew:    %d\n", tooNew)
+			fmt.Fprintf(os.Stderr, "  dirHash infoErr:   %d\n", infoErr)
+			fmt.Fprintf(os.Stderr, "  dirHash git hit:   %d\n", gitHit)
+			fmt.Fprintf(os.Stderr, "  dirHash git miss:  %d\n", gitMiss)
+			fmt.Fprintf(os.Stderr, "  getFileInfo calls: %d\n", fileInfoCalls)
+			if b.gitIndex != nil {
+				fmt.Fprintf(os.Stderr, "  git index entries: %d\n", b.gitIndex.Len())
+			}
+			fmt.Fprintf(os.Stderr, "======================\n")
+		})
+	}
+}
+
+// gitBlobHash looks up the file's blob SHA1 in the git index using
+// binary search. The absolute path is converted to a repo-relative
+// path for the lookup. Only the returned hex string is allocated.
+func (b *Builder) gitBlobHash(file string) (string, bool) {
+	if b.gitIndex == nil {
+		return "", false
+	}
+	rel, ok := strings.CutPrefix(file, b.gitRepoRoot)
+	if !ok {
+		return "", false
+	}
+	return b.gitIndex.Lookup(rel)
+}
