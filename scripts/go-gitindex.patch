new file mode 100644
index 0000000000..713f5fb766
--- /dev/null
+++ b/src/cmd/go/internal/vcs/git_index.go
@@ -0,0 +1,215 @@
+// Copyright 2024 The Go Authors. All rights reserved.
+// Use of this source code is governed by a BSD-style
+// license that can be found in the LICENSE file.
+
+package vcs
+
+import (
+	"encoding/binary"
+	"encoding/hex"
+	"fmt"
+	"os"
+	"path/filepath"
+	"strings"
+)
+
+// A GitIndex provides efficient lookup of blob SHA1 by relative path
+// from a parsed .git/index file.
+//
+// The git index stores entries sorted by path. At parse time, path
+// names and SHA1 bytes are copied into compact contiguous buffers and
+// the raw index data is released. Lookups use binary search with
+// allocation-free string-to-bytes comparison; only the returned hex
+// string is allocated.
+type GitIndex struct {
+	names   []byte   // all path names concatenated
+	sha1s   []byte   // all SHA1s concatenated (20 bytes each)
+	nameOff []uint32 // start of each name in names[]
+	nameLen []uint16 // length of each name
+}
+
+const (
+	gitIndexHeaderSize = 12
+	gitIndexEntryFixed = 62 // stat(40) + SHA1(20) + flags(2)
+)
+
+// ReadGitIndex reads and parses the git index file in gitDir.
+func ReadGitIndex(gitDir string) (*GitIndex, error) {
+	data, err := os.ReadFile(filepath.Join(gitDir, "index"))
+	if err != nil {
+		return nil, err
+	}
+	return parseGitIndex(data)
+}
+
+func parseGitIndex(data []byte) (*GitIndex, error) {
+	if len(data) < gitIndexHeaderSize {
+		return nil, fmt.Errorf("git index: truncated header")
+	}
+	if string(data[:4]) != "DIRC" {
+		return nil, fmt.Errorf("git index: bad magic %q", data[:4])
+	}
+
+	version := binary.BigEndian.Uint32(data[4:8])
+	if version != 2 && version != 3 {
+		return nil, fmt.Errorf("git index: unsupported version %d", version)
+	}
+
+	numEntries := binary.BigEndian.Uint32(data[8:12])
+
+	// Pre-allocate based on entry count. Average path ~30 bytes.
+	names := make([]byte, 0, numEntries*30)
+	sha1s := make([]byte, 0, numEntries*20)
+	nameOff := make([]uint32, 0, numEntries)
+	nameLen := make([]uint16, 0, numEntries)
+
+	offset := gitIndexHeaderSize
+	for i := uint32(0); i < numEntries; i++ {
+		if offset+gitIndexEntryFixed > len(data) {
+			return nil, fmt.Errorf("git index: truncated entry %d", i)
+		}
+
+		entryStart := offset
+
+		flags := binary.BigEndian.Uint16(data[offset+60 : offset+62])
+		stage := (flags >> 12) & 0x3
+		nLen := int(flags & 0xFFF)
+
+		offset += gitIndexEntryFixed
+
+		// v3 extended flags
+		if version == 3 && (flags>>14)&0x1 == 1 {
+			if offset+2 > len(data) {
+				return nil, fmt.Errorf("git index: truncated extended flags entry %d", i)
+			}
+			offset += 2
+		}
+
+		nameStart := offset
+
+		// Resolve actual name length for names >= 0xFFF.
+		if nLen >= 0xFFF {
+			end := offset
+			for end < len(data) && data[end] != 0 {
+				end++
+			}
+			if end >= len(data) {
+				return nil, fmt.Errorf("git index: unterminated name entry %d", i)
+			}
+			nLen = end - offset
+		} else if offset+nLen > len(data) {
+			return nil, fmt.Errorf("git index: truncated name entry %d", i)
+		}
+
+		// Advance past name + NUL padding to 8-byte boundary.
+		entryLen := (nameStart - entryStart) + nLen
+		offset = entryStart + (entryLen+8)&^7
+
+		if stage != 0 {
+			continue
+		}
+
+		// Copy name and SHA1 into contiguous buffers.
+		nameOff = append(nameOff, uint32(len(names)))
+		nameLen = append(nameLen, uint16(nLen))
+		names = append(names, data[nameStart:nameStart+nLen]...)
+		sha1s = append(sha1s, data[entryStart+40:entryStart+60]...)
+	}
+
+	return &GitIndex{
+		names:   names,
+		sha1s:   sha1s,
+		nameOff: nameOff,
+		nameLen: nameLen,
+	}, nil
+}
+
+// Len returns the number of stage-0 entries.
+func (idx *GitIndex) Len() int {
+	return len(idx.nameOff)
+}
+
+// Lookup returns the blob SHA1 hex string for the given relative path
+// using binary search. Only the returned hex string is allocated.
+func (idx *GitIndex) Lookup(path string) (string, bool) {
+	lo, hi := 0, len(idx.nameOff)
+	for lo < hi {
+		mid := lo + (hi-lo)/2
+		cmp := compareStringToBytes(path, idx.name(mid))
+		if cmp < 0 {
+			hi = mid
+		} else if cmp > 0 {
+			lo = mid + 1
+		} else {
+			off := mid * 20
+			return hex.EncodeToString(idx.sha1s[off : off+20]), true
+		}
+	}
+	return "", false
+}
+
+// name returns the raw name bytes for the i-th entry. No allocation.
+func (idx *GitIndex) name(i int) []byte {
+	off := idx.nameOff[i]
+	return idx.names[off : off+uint32(idx.nameLen[i])]
+}
+
+// compareStringToBytes compares string s to byte slice b
+// lexicographically without allocating. Returns -1, 0, or 1.
+func compareStringToBytes(s string, b []byte) int {
+	n := len(s)
+	if len(b) < n {
+		n = len(b)
+	}
+	for i := 0; i < n; i++ {
+		if s[i] < b[i] {
+			return -1
+		}
+		if s[i] > b[i] {
+			return 1
+		}
+	}
+	if len(s) < len(b) {
+		return -1
+	}
+	if len(s) > len(b) {
+		return 1
+	}
+	return 0
+}
+
+// ResolveGitDir takes a repo root directory (as returned by FromDir)
+// and returns the path to the .git directory containing the index file.
+// For regular repos this is repoRoot/.git; for worktrees it follows
+// the gitdir pointer. Returns "" if the .git directory cannot be resolved.
+// This mirrors the logic in vcsGitRoot.isRoot.
+func ResolveGitDir(repoRoot string) string {
+	path := filepath.Join(repoRoot, ".git")
+	fi, err := os.Stat(path)
+	if err != nil {
+		return ""
+	}
+	if fi.IsDir() {
+		return path
+	}
+	// Worktree: .git is a file with "gitdir: <path>".
+	if !fi.Mode().IsRegular() || fi.Size() == 0 || fi.Size() > 4096 {
+		return ""
+	}
+	raw, err := os.ReadFile(path)
+	if err != nil {
+		return ""
+	}
+	rest, ok := strings.CutPrefix(string(raw), "gitdir:")
+	if !ok {
+		return ""
+	}
+	gitdir := strings.TrimSpace(rest)
+	if gitdir == "" {
+		return ""
+	}
+	if !filepath.IsAbs(gitdir) {
+		gitdir = filepath.Join(repoRoot, gitdir)
+	}
+	return gitdir
+}
