{
  "permissions": {
    "allow": [
      "Bash(roxctl central generate *)",
      "Bash(MIGRATION/strip-randomness.sh *)",
      "Bash(diff -r *)",
      "Bash(rm -rf MIGRATION/opt-*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gofmt-hook.sh"
          }
        ]
      }
    ]
  }
}