      "get": {
        "summary": "GetComplianceScanCheckResult returns the specific result by ID.",
        "description": "Returns the full cross-cluster check status including per-cluster outcomes,\nremediation instructions, rationale, and mapped compliance controls.\n\nReturns NOT_FOUND if no result with the given ID exists.\nReturns INVALID_ARGUMENT if the ID is empty.",
        "operationId": "ComplianceResultsService_GetComplianceScanCheckResult",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v2ComplianceClusterCheckStatus"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "ComplianceResultsService"
        ]
      }
    },
