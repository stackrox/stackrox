  "paths": {
    "/v2/compliance/profile/{id}": {
      "get": {
        "summary": "GetComplianceProfile retrieves the specified compliance profile by ID.",
        "description": "Returns the full profile including its rules and associated benchmark standards.\n\nReturns NOT_FOUND if no profile with the given ID exists.\nReturns INVALID_ARGUMENT if the ID is empty.",
        "operationId": "ComplianceProfileService_GetComplianceProfile",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v2ComplianceProfile"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "ComplianceProfileService"
        ]
      }
    },
    "/v2/compliance/profiles/cluster": {
      "get": {
        "summary": "ListComplianceProfiles returns profiles matching given request",
        "description": "Returns all compliance profiles available on the specified cluster, including\ntheir full rule lists and benchmark mappings. The cluster_id is required.\nSupports pagination and search query filtering.\n\nReturns INVALID_ARGUMENT if cluster_id is empty or the query is malformed.",
        "operationId": "ComplianceProfileService_ListComplianceProfiles",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v2ListComplianceProfilesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "clusterId",
            "description": "cluster_id is required and restricts results to profiles installed on this cluster.",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "query.query",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "query.pagination.limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "query.pagination.offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "query.pagination.sortOption.field",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "query.pagination.sortOption.reversed",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "query.pagination.sortOption.aggregateBy.aggrFunc",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "UNSET",
              "COUNT",
              "MIN",
              "MAX"
            ],
            "default": "UNSET"
          },
          {
            "name": "query.pagination.sortOption.aggregateBy.distinct",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "ComplianceProfileService"
        ]
      }
    },
    "/v2/compliance/profiles/summary": {
      "get": {
        "summary": "ListProfileSummaries returns profiles matching each cluster and the given query",
        "description": "Returns a deduplicated list of profile summaries across the specified clusters.\nResults are sorted by profile name. At least one cluster ID is required.\nSupports pagination; total_count reflects distinct profile names, not raw rows.\n\nReturns INVALID_ARGUMENT if no cluster IDs are provided or the query is malformed.",
        "operationId": "ComplianceProfileService_ListProfileSummaries",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v2ListComplianceProfileSummaryResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "clusterIds",
            "description": "cluster_ids is required; at least one cluster ID must be provided.",
            "in": "query",
            "required": false,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "query.query",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "query.pagination.limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "query.pagination.offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "query.pagination.sortOption.field",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "query.pagination.sortOption.reversed",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "query.pagination.sortOption.aggregateBy.aggrFunc",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "UNSET",
              "COUNT",
              "MIN",
              "MAX"
            ],
            "default": "UNSET"
          },
          {
            "name": "query.pagination.sortOption.aggregateBy.distinct",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "ComplianceProfileService"
        ]
      }
    }
  },
