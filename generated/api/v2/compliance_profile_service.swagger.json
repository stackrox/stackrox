        }
      }
    },
    "v2ComplianceProfile": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "profileVersion": {
          "type": "string",
          "description": "profile_version is the version string of this profile (e.g. \"1.4.0\")."
        },
        "productType": {
          "type": "string",
          "description": "product_type describes the target product category (e.g. \"Platform\", \"Node\")."
        },
        "description": {
          "type": "string",
          "description": "description is the human-readable description of the profile's purpose and scope."
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v2ComplianceRule"
          },
          "description": "rules lists the compliance rules that are part of this profile."
        },
        "product": {
          "type": "string",
          "description": "product is the name of the product this profile applies to (e.g. \"OpenShift\")."
        },
        "title": {
          "type": "string",
          "description": "title is the display name of the profile (e.g. \"CIS Red Hat OpenShift Container Platform 4 Benchmark\")."
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "values lists the variable values applied to this profile's checks."
        },
        "standards": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v2ComplianceBenchmark"
          },
          "description": "standards lists the compliance benchmarks (e.g. CIS, NIST) that this profile maps to."
        },
        "operatorKind": {
          "$ref": "#/definitions/v2ComplianceProfileOperatorKind",
          "description": "operator_kind indicates whether this profile originates from a Compliance Operator\nProfile or TailoredProfile resource."
        }
      },
      "description": "Next Tag: 13\nComplianceProfile represents a compliance profile sourced from the Compliance Operator.\nA profile defines a set of rules and benchmarks that are evaluated during a compliance scan."
    },
    "v2ComplianceProfileOperatorKind": {
      "type": "string",
      "enum": [
        "OPERATOR_KIND_UNSPECIFIED",
        "PROFILE",
        "TAILORED_PROFILE"
      ],
      "default": "OPERATOR_KIND_UNSPECIFIED",
      "description": "OperatorKind is the kind of the Compliance Operator resource that this\n`ComplianceProfile` was sourced from. ACS represents both Compliance\nOperator `Profiles` and `TailoredProfiles` as compliance profiles.\n\n - OPERATOR_KIND_UNSPECIFIED: The kind is unspecified.\n - PROFILE: The kind is `Profile`.\n - TAILORED_PROFILE: The kind is `TailoredProfile`."
    },
