  "paths": {
    "/v2/images/metadata": {
      "post": {
        "summary": "GetImageMetadata returns reduced image metadata (names and layers) for specified images.",
        "operationId": "ImageService_GetImageMetadata",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v2GetImageMetadataResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "GetImageMetadataRequest requests reduced image metadata (names and layers)\nfor specified images.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v2GetImageMetadataRequest"
            }
          }
        ],
        "tags": [
          "ImageService"
        ]
      }
    }
  },
  "definitions": {
    "GetImageMetadataRequestLayers": {
      "type": "object",
      "properties": {
        "layers": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "int32"
          },
          "description": "If layer indices list is empty for an image, no layers are included.\nIf layer indices list is nil for an image, all layers are included."
        }
      }
    },
    "GetImageMetadataResponseMetadata": {
      "type": "object",
      "properties": {
        "names": {
