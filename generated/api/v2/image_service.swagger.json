          }
        },
        "baseImage": {
          "type": "string",
          "description": "The name of the base image for this image or empty."
        },
        "isBaseImage": {
          "type": "string",
          "description": "Whether this image is a base image for other images."
        }
      }
    },
    "MetadataImageLayer": {
      "type": "object",
      "properties": {
        "instruction": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "author": {
          "type": "string"
        },
        "empty": {
          "type": "boolean"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v2GetImageMetadataRequest": {
      "type": "object",
      "properties": {
        "images": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/GetImageMetadataRequestLayers"
          },
          "description": "Map of image SHA to list of requested layer indices for that image.\nIf the map is empty, all images are returned."
        },
        "query": {
          "type": "string",
          "description": "Optional query."
        }
      },
      "description": "GetImageMetadataRequest requests reduced image metadata (names and layers)\nfor specified images."
