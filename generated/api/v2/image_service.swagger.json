    "v2GetImageMetadataResponse": {
      "type": "object",
      "properties": {
        "images": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/GetImageMetadataResponseMetadata"
          },
          "description": "Map of image SHA to metadata."
        }
      },
      "description": "GetImageMetadataResponse returns reduced image metadata (names and layers)."
    }
