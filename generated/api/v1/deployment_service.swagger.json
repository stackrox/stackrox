  "paths": {
    "/v1/deployments": {
      "get": {
        "summary": "ListDeployments returns a paginated list of slim deployment summaries\nmatching the query.",
        "description": "Each result is a storage.ListDeployment containing only identity and summary\nfields (id, name, cluster, namespace, created, priority). Use GetDeployment\nto retrieve the full object for a specific deployment.\n\nResults are capped at 1000 deployments per request. Use pagination to page\nthrough larger result sets. Supports sorting via the pagination.sortOption\nfield (e.g., by \"Deployment Risk Priority\").\n\nUses StackRox search query syntax. Searchable fields include Cluster,\nNamespace, Deployment, Deployment Type, and Deployment Label.\n\nReturns INVALID_ARGUMENT if the query syntax is malformed.",
        "operationId": "DeploymentService_ListDeployments",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListDeploymentsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "query",
            "description": "query is a StackRox search query string. Multiple field:value pairs are\njoined with \"+\" (AND). Multiple values for one field are joined with \",\"\n(OR). Example: \"Severity:CRITICAL+Cluster:production\"",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "pagination.limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pagination.offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pagination.sortOption.field",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "pagination.sortOption.reversed",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "pagination.sortOption.aggregateBy.aggrFunc",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "UNSET",
              "COUNT",
              "MIN",
              "MAX"
            ],
            "default": "UNSET"
          },
          {
            "name": "pagination.sortOption.aggregateBy.distinct",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "DeploymentService"
        ]
      }
    },
    "/v1/deployments/metadata/labels": {
      "get": {
        "summary": "GetLabels returns all label keys and their observed values across all\ndeployments visible to the caller.",
        "description": "The response contains a map of label key to sorted list of distinct values,\nplus a flat sorted list of all values across all keys. This is typically\nused to populate filter dropdowns in the UI.\n\nNo query filtering is applied; all deployment labels are always returned.",
        "operationId": "DeploymentService_GetLabels",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1DeploymentLabelsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "tags": [
          "DeploymentService"
        ]
      }
    },
    "/v1/deployments/{id}": {
      "get": {
        "summary": "GetDeployment returns the full deployment object with the given ID.",
        "description": "Returns NOT_FOUND if no deployment with the given ID exists within the\ncaller's authorized scope.",
        "operationId": "DeploymentService_GetDeployment",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/storageDeployment"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "DeploymentService"
        ]
      }
    },
    "/v1/deploymentscount": {
      "get": {
        "summary": "CountDeployments returns the number of deployments that match the query.",
        "description": "Uses StackRox search query syntax. If the query is empty, counts all\ndeployments visible to the caller.\nExample query: \"Cluster:production+Namespace:payments\"\n\nReturns INVALID_ARGUMENT if the query syntax is malformed.",
        "operationId": "DeploymentService_CountDeployments",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CountDeploymentsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "query",
            "description": "query is a StackRox search query string. Multiple field:value pairs are\njoined with \"+\" (AND). Multiple values for one field are joined with \",\"\n(OR). Example: \"Severity:CRITICAL+Cluster:production\"",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "pagination.limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pagination.offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pagination.sortOption.field",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "pagination.sortOption.reversed",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "pagination.sortOption.aggregateBy.aggrFunc",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "UNSET",
              "COUNT",
              "MIN",
              "MAX"
            ],
            "default": "UNSET"
          },
          {
            "name": "pagination.sortOption.aggregateBy.distinct",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "DeploymentService"
        ]
      }
    },
    "/v1/deploymentswithprocessinfo": {
      "get": {
        "summary": "ListDeploymentsWithProcessInfo returns a paginated list of slim deployment\nsummaries, each paired with per-container process baseline evaluation results.",
        "description": "Applies the same query, pagination, and 1000-result cap as ListDeployments.\n\nBaseline statuses indicate whether each container's process baseline is\nlocked, unlocked, or not yet generated, and whether anomalous processes have\nbeen observed. Baseline statuses are only populated when the caller has\nread access to the DeploymentExtension resource in addition to Deployment.\nIf the caller lacks DeploymentExtension access, deployments are still\nreturned but baseline_statuses will be empty on each entry.\n\nReturns INVALID_ARGUMENT if the query syntax is malformed.",
        "operationId": "DeploymentService_ListDeploymentsWithProcessInfo",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListDeploymentsWithProcessInfoResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "query",
            "description": "query is a StackRox search query string. Multiple field:value pairs are\njoined with \"+\" (AND). Multiple values for one field are joined with \",\"\n(OR). Example: \"Severity:CRITICAL+Cluster:production\"",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "pagination.limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pagination.offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pagination.sortOption.field",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "pagination.sortOption.reversed",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "pagination.sortOption.aggregateBy.aggrFunc",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "UNSET",
              "COUNT",
              "MIN",
              "MAX"
            ],
            "default": "UNSET"
          },
          {
            "name": "pagination.sortOption.aggregateBy.distinct",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "DeploymentService"
        ]
      }
    },
    "/v1/deploymentswithrisk/{id}": {
      "get": {
        "summary": "GetDeploymentWithRisk returns the full deployment object together with its\ncomputed risk score and the individual factors that contributed to it.",
        "description": "Risk is calculated by the StackRox risk engine and reflects security\nposture signals such as image vulnerabilities, exposed ports, and\nprivileged container settings.\n\nReturns NOT_FOUND if no deployment with the given ID exists within the\ncaller's authorized scope.",
        "operationId": "DeploymentService_GetDeploymentWithRisk",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetDeploymentWithRiskResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "DeploymentService"
        ]
      }
    },
    "/v1/export/deployments": {
      "get": {
        "summary": "ExportDeployments streams full deployment objects matching the query as a\nserver-sent stream of ExportDeploymentResponse messages.",
        "description": "Unlike ListDeployments, this endpoint streams full storage.Deployment objects\n(not slim summaries) and has no upper bound on the number of results. It is\nintended for bulk data export scenarios.\n\nAn optional timeout (in seconds) can be set on the request; if the stream\ndoes not complete within the timeout, it is cancelled.\n\nReturns INVALID_ARGUMENT if the query syntax is malformed.",
        "operationId": "DeploymentService_ExportDeployments",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/v1ExportDeploymentResponse"
                },
                "error": {
                  "$ref": "#/definitions/googleRpcStatus"
                }
              },
              "title": "Stream result of v1ExportDeploymentResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "timeout",
            "description": "timeout is an optional deadline in seconds for the streaming export.\nIf zero, no deadline is applied. If positive, the stream will be\ncancelled after this many seconds.",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "query",
            "description": "query filters exported deployments using StackRox search syntax.\nIf empty, all deployments visible to the caller are exported.\nExample: \"Cluster:production+Namespace:payments\"",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "DeploymentService"
        ]
      }
    }
  },
