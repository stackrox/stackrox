{
	"build":{
		"dockerfile":"Dockerfile"
	},
	"remoteEnv":{
		"PATH":"${containerEnv:PATH}:/workspaces/stackrox/.gotools/bin/"
	},
	"forwardPorts":[
		"db:5432"
	],
	"postCreateCommand":"git config --global --add safe.directory /workspaces/stackrox && claude mcp add -s user --transport http atlassian https://mcp.atlassian.com/v1/mcp && make dev deps",
	"customizations":{
		"paude":{
			"create":{
				"allowed-domains":["default","golang","nodejs","redhat.atlassian.net","mcp.atlassian.com","cf.mcp.atlassian.com"]
			},
			"secretEnv": ["JIRA_API_TOKEN"]
		},
		"vscode":{
			"extensions":[
				"golang.go",
				"eamodio.gitlens",
				"zxh404.vscode-proto3",
				"ms-azuretools.vscode-docker",
				"redhat.vscode-yaml",
				"IBM.output-colorizer"
			],
			"settings":{
				"files.eol":"\n",
				"go.useLanguageServer":true,
				"go.lintTool":"golangci-lint"
			}
		}
	}
}
